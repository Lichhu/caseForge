{
  "name": "@case-forge/api",
  "version": "0.1.0",
  "private": true,
  "description": "CaseForge NestJS API",
  "main": "src/bootstrap.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nest start --debug --watch --entryFile bootstrap",
    "local": "cross-env NODE_ENV=local nest start --debug --watch --entryFile bootstrap",
    "start": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/bootstrap.ts",
    "build": "nest build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier \"src/**/*.ts\" --write",
    "seed:demo": "cross-env NODE_ENV=local ts-node -r tsconfig-paths/register scripts/seed-demo-data.ts",
    "seed:api-test": "cross-env NODE_ENV=local ts-node -r tsconfig-paths/register scripts/seed-api-test-demo.ts",
    "seed:api-scenarios": "cross-env NODE_ENV=local ts-node -r tsconfig-paths/register scripts/seed-api-scenarios.ts",
    "db:indexes": "echo '请在 MySQL 中执行: source apps/api/scripts/add-database-indexes.sql'",
    "db:platform": "echo '请在 MySQL 中执行: source apps/api/scripts/add-project-platform-column.sql'"
  },
  "dependencies": {
    "@case-forge/shared": "workspace:*",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "iconv-lite": "^0.6.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "marked": "^12.0.2",
    "minio": "^8.0.7",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "nanoid": "^5.0.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/express": "^4.17.21",
    "@types/multer": "1.4.12",
    "@types/node": "^20.14.12",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.13.4",
    "cross-env": "^7.0.3",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
